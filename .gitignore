```gitignore
# ======================================================
# Python
# ======================================================
__pycache__/
*.py[cod]
*$py.class
*.so

# Virtual Environments
.venv/
venv/
env/
ENV/

# ======================================================
# IDEs
# ======================================================
.vscode/
.idea/
*.swp
*.swo

# macOS
.DS_Store

# ======================================================
# Logs
# ======================================================
*.log
logs/
outputs/logs/

# ======================================================
# Testing / Coverage
# ======================================================
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
.mypy_cache/
.ruff_cache/

# ======================================================
# Jupyter
# ======================================================
.ipynb_checkpoints/

# ======================================================
# Environment Variables
# ======================================================
.env
.env.*

# ======================================================
# Build / Distribution
# ======================================================
build/
dist/
*.egg-info/

# ======================================================
# Models (Large Files)
# ======================================================
models/*.pt
models/*.onnx
models/*.engine
models/*.tflite
models/*.ckpt
models/*.pth

# ======================================================
# Videos
# ======================================================
videos/raw/*
videos/processed/*

# Keep folder structure
!videos/raw/.gitkeep
!videos/processed/.gitkeep

# ======================================================
# Outputs
# ======================================================
outputs/*
!outputs/.gitkeep

# Or keep empty subfolders
!outputs/images/
!outputs/clips/
!outputs/logs/

outputs/images/*
outputs/clips/*
outputs/logs/*

!outputs/images/.gitkeep
!outputs/clips/.gitkeep
!outputs/logs/.gitkeep

# ======================================================
# Temporary Files
# ======================================================
*.tmp
*.temp
*.bak

# ======================================================
# SQLite Databases
# ======================================================
*.db
*.sqlite
*.sqlite3

# ======================================================
# Streamlit
# ======================================================
.streamlit/secrets.toml

# ======================================================
# OS Files
# ======================================================
Thumbs.db
Desktop.ini

# ======================================================
# FFmpeg Temporary Files
# ======================================================
*.ts
*.m3u8

# ======================================================
# Misc
# ======================================================
.cache/
```
